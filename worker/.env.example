# ===========================================
# Barueri Empregabilidade — Worker (FastAPI)
# ===========================================
# Copie este arquivo para .env e preencha com os valores reais

# Supabase (novo projeto Barueri)
SUPABASE_URL=https://<novo-projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# UAZAPI (nova conta Barueri)
UAZAPI_BASE_URL=https://uazapi.com.br

# Token interno portal <-> worker
WEBHOOK_INTERNAL_TOKEN=cuca_internal_token_2026

# URL pública do frontend no EasyPanel
PORTAL_URL=https://<url-publica-barueri-portal>

# OpenAI
OPENAI_API_KEY=

# Sentry (opcional)
SENTRY_DSN_WORKER=

# Ambiente
ENVIRONMENT=production
APP_VERSION=1.0.0
DEBUG=False
